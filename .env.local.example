# Server-only. Get your key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_or_anon_key

# Optional alias used by local scripts.
SUPABASE_URL=https://your-project-ref.supabase.co

# Server-only key used by local seed scripts. Never expose in frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Used to add a secret pepper before hashing invite PINs.
# Generate locally with: openssl rand -base64 32
INVITE_CODE_PEPPER=

# Optional demo-seed overrides.
DEMO_ARCHIVE_EMAIL=demo@genie.local
DEMO_ARCHIVE_PASSWORD=DemoFamily2026!
DEMO_ARCHIVE_PIN=FAMILY-DEMO-2026
DEMO_ARCHIVE_DISPLAY_NAME=Demo Family
